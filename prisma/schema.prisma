// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  WALLET
  CASH
  MONNIFY
}

enum TransactionType {
  DEPOSIT
  BOOKING_PAYMENT
  DEBIT
  CREDIT
  REFUND
  INFLUENCER_REWARD
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TransactionPaymentMethod {
  WALLET
  REFERRAL
  PAYSTACK
  MONNIFY
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum ReferralRewardType {
  FIXED
  PERCENTAGE
}

enum ReferralStatus {
  PENDING
  REWARDED
  FAILED
}

enum DiscountType {
  GENERAL
  INFLUENCER
}

enum BookingType {
  HOME_SERVICE
  WALK_IN
  MIXED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
}

enum StaffEmploymentStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  EXITED
  ARCHIVED
}

enum StaffEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  phone            String?
  role             UserRole  @default(USER)
  status           UserStatus @default(ACTIVE)
  emailVerified    Boolean   @default(false) @map("email_verified")
  otpCode          String?   @map("otp_code")
  otpExpiry        DateTime? @map("otp_expiry")
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  currentSessionId String?   @map("current_session_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  adminRoleId      String?    @map("admin_role_id")

  // Relations
  addresses       Address[]
  bookings        Booking[]
  wallet          Wallet?
  reviews         Review[]
  refreshTokens   RefreshToken[]
  referralCode    ReferralCode?
  referrals       Referral[]     @relation("ReferrerUser")
  referredBy      Referral?      @relation("ReferredUser")
  referralCampaignUsages ReferralCampaignCodeUsage[]
  discountUsages  DiscountUsage[] @relation("UserDiscountUsages")
  adminRole       AdminRole?     @relation(fields: [adminRoleId], references: [id], onDelete: SetNull)
  influencer      Influencer?

  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Address {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  label        String?  // e.g., "Home", "Office"
  fullAddress  String   @map("full_address")
  streetAddress String? @map("street_address")
  city         String?
  state        String?
  country      String   @default("Nigeria")
  placeId      String?  @map("place_id")
  addressComponents Json? @map("address_components")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([userId])
  @@map("addresses")
}

model ServiceCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  services Service[]

  @@map("service_categories")
}

model Service {
  id          String        @id @default(uuid())
  categoryId  String        @map("category_id")
  name        String
  description String?
  walkInPrice Decimal       @db.Decimal(10, 2) @map("walk_in_price")
  homeServicePrice Decimal  @db.Decimal(10, 2) @map("home_service_price")
  isWalkInAvailable Boolean @default(true) @map("is_walk_in_available")
  isHomeServiceAvailable Boolean @default(true) @map("is_home_service_available")
  duration    Int           // Duration in minutes
  imageUrl    String?       @map("image_url")
  imagePublicId String?     @map("image_public_id")
  status      ServiceStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  category ServiceCategory @relation(fields: [categoryId], references: [id])
  reviews  Review[]

  @@map("services")
}

model Booking {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  // services is a JSON array: [{serviceId, name, price, duration, notes?}]
  services         Json          @map("services")
  addressId        String?       @map("address_id")  // null for WALK_IN-only bookings
  bookingDate      DateTime      @map("booking_date")
  bookingTime      String        @map("booking_time") // Format: "HH:mm"
  bookingType      BookingType   @default(HOME_SERVICE) @map("booking_type")
  reservationCode  String        @unique @map("reservation_code")
  reservationUsed  Boolean       @default(false) @map("reservation_used")
  guestName        String?       @map("guest_name")   // null = booking for self
  guestPhone       String?       @map("guest_phone")  // null = booking for self
  guestEmail       String?       @map("guest_email")  // if set, notification email sent to guest
  idempotencyKey   String?       @map("idempotency_key")
  status           BookingStatus @default(PENDING)
  paymentMethod    PaymentMethod @map("payment_method")
  totalAmount      Decimal       @db.Decimal(10, 2) @map("total_amount")
  notes            String?
  cancelReason     String?       @map("cancel_reason")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id])
  address Address? @relation(fields: [addressId], references: [id])
  review  Review?
  discountUsage DiscountUsage?

  @@index([reservationCode])
  @@index([userId])
  @@index([status])
  @@index([bookingDate])
  @@index([userId, status])
  @@unique([userId, idempotencyKey])
  @@map("bookings")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id                String            @id @default(uuid())
  walletId          String            @map("wallet_id")
  type              TransactionType
  amount            Decimal           @db.Decimal(10, 2)
  status            TransactionStatus @default(PENDING)
  paymentMethod     TransactionPaymentMethod @default(WALLET) @map("payment_method")
  reference         String            @unique // Payment gateway reference or internal ref
  description       String?
  metadata          Json?             // Store additional payment details
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  wallet           Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  influencerReward InfluencerReward?
  referralCampaignUsage ReferralCampaignCodeUsage?

  @@index([walletId])
  @@index([walletId, status])
  @@map("transactions")
}

model Review {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  serviceId String       @map("service_id")
  bookingId String       @unique @map("booking_id")
  rating    Int          // 1-5
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([serviceId])
  @@index([status])
  @@map("reviews")
}

model BusinessSettings {
  id                 String   @id @default(uuid())
  businessName       String   @map("business_name")
  email              String
  phone              String
  address            String
  slotDuration       Int      @default(30) @map("slot_duration")        // Booking slot length in minutes
  advanceBookingDays Int      @default(30) @map("advance_booking_days") // How many days ahead bookings allowed
  minNoticeHours     Int      @default(2) @map("min_notice_hours")      // Minimum hours before a booking
  maxBookingsPerDay  Int      @default(10) @map("max_bookings_per_day")
  bookingPolicy      String?  @map("booking_policy")
  cancellationPolicy String?  @map("cancellation_policy")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("business_settings")
}

model BusinessHours {
  id        String   @id @default(uuid())
  dayOfWeek Int      @unique @map("day_of_week") // 0=Sunday, 1=Monday ... 6=Saturday
  openTime  String   @map("open_time")            // Format: "HH:mm"
  closeTime String   @map("close_time")           // Format: "HH:mm"
  isOpen    Boolean  @default(true) @map("is_open")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("business_hours")
}

model BusinessException {
  id        String   @id @default(uuid())
  date      DateTime @unique                      // Specific calendar date
  isClosed  Boolean  @default(true) @map("is_closed")
  openTime  String?  @map("open_time")            // Override open time (only if not closed)
  closeTime String?  @map("close_time")           // Override close time (only if not closed)
  reason    String?                               // e.g. "Christmas Holiday"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("business_exceptions")
}

model Influencer {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")  // linked user account
  notes       String?   // internal admin notes
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  discountCodes    DiscountCode[]
  influencerRewards InfluencerReward[]

  @@map("influencers")
}

model DiscountCode {
  id              String       @id @default(uuid())
  code            String       @unique              // e.g. "SUMMER20" — case-insensitive at app level
  name            String                            // e.g. "Summer Sale"
  percentage      Float                             // e.g. 20.0 (represents 20%)
  type            DiscountType @default(GENERAL) @map("type")
  influencerId    String?      @map("influencer_id")   // null for GENERAL codes
  isActive        Boolean      @default(true) @map("is_active")
  startsAt        DateTime?    @map("starts_at")    // null = active immediately
  expiresAt       DateTime?    @map("expires_at")   // null = never expires
  maxUses         Int?         @map("max_uses")     // null = unlimited
  usedCount       Int          @default(0) @map("used_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  influencer Influencer?   @relation(fields: [influencerId], references: [id], onDelete: SetNull)
  usages     DiscountUsage[]

  @@index([influencerId])
  @@map("discount_codes")
}

model DiscountUsage {
  id             String   @id @default(uuid())
  discountCodeId String   @map("discount_code_id")
  userId         String   @map("user_id")
  bookingId      String   @unique @map("booking_id")
  discountAmount Decimal  @db.Decimal(10, 2) @map("discount_amount")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  discountCode     DiscountCode      @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  user             User              @relation("UserDiscountUsages", fields: [userId], references: [id])
  booking          Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  influencerReward InfluencerReward?

  @@index([discountCodeId])
  @@index([userId])
  @@map("discount_usages")
}

model InfluencerRewardSettings {
  id                String             @id @default(uuid())
  isActive          Boolean            @default(false) @map("is_active")
  rewardType        ReferralRewardType @default(FIXED) @map("reward_type")
  rewardValue       Decimal            @default(0) @db.Decimal(10, 2) @map("reward_value")
  minPurchaseAmount Decimal            @default(0) @db.Decimal(10, 2) @map("min_purchase_amount")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@map("influencer_reward_settings")
}

model InfluencerReward {
  id                  String         @id @default(uuid())
  influencerId        String         @map("influencer_id")
  usageId             String         @unique @map("usage_id")
  walletTransactionId String?        @unique @map("wallet_transaction_id")
  rewardAmount        Decimal        @db.Decimal(10, 2) @map("reward_amount")
  status              ReferralStatus @default(REWARDED)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // Relations
  influencer       Influencer    @relation(fields: [influencerId], references: [id])
  usage            DiscountUsage @relation(fields: [usageId], references: [id], onDelete: Cascade)
  walletTransaction Transaction?  @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)

  @@index([influencerId])
  @@map("influencer_rewards")
}

// ─── Referral System ─────────────────────────────────────────────────────────

model ReferralSettings {
  id               String             @id @default(uuid())
  isActive         Boolean            @default(false) @map("is_active")
  rewardType       ReferralRewardType @default(FIXED) @map("reward_type")
  rewardValue      Decimal            @db.Decimal(10, 2) @map("reward_value")
  minDepositAmount Decimal            @default(0) @db.Decimal(10, 2) @map("min_deposit_amount")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@map("referral_settings")
}

model ReferralCode {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  code        String   @unique
  totalUses   Int      @default(0) @map("total_uses")
  totalEarned Decimal  @default(0) @db.Decimal(10, 2) @map("total_earned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals Referral[] @relation("ReferrerCode")

  @@map("referral_codes")
}

model Referral {
  id           String         @id @default(uuid())
  referrerId   String         @map("referrer_id")
  referredId   String         @unique @map("referred_id") // one referral per user
  code         String
  status       ReferralStatus @default(PENDING)
  rewardAmount Decimal?       @db.Decimal(10, 2) @map("reward_amount")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  // Relations
  referrer     User         @relation("ReferrerUser", fields: [referrerId], references: [id])
  referred     User         @relation("ReferredUser", fields: [referredId], references: [id])
  referralCode ReferralCode @relation("ReferrerCode", fields: [code], references: [code])

  @@index([referrerId])
  @@index([status])
  @@map("referrals")
}

model ReferralCampaignCode {
  id                String   @id @default(uuid())
  code              String   @unique
  name              String
  description       String?
  signupBonusAmount Decimal  @db.Decimal(10, 2) @map("signup_bonus_amount")
  isActive          Boolean  @default(true) @map("is_active")
  startsAt          DateTime? @map("starts_at")
  expiresAt         DateTime? @map("expires_at")
  maxUses           Int?     @map("max_uses")
  usedCount         Int      @default(0) @map("used_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  usages ReferralCampaignCodeUsage[]

  @@index([isActive])
  @@map("referral_campaign_codes")
}

model ReferralCampaignCodeUsage {
  id             String   @id @default(uuid())
  campaignCodeId String   @map("campaign_code_id")
  userId         String   @unique @map("user_id")
  transactionId  String?  @unique @map("transaction_id")
  bonusAmount    Decimal  @db.Decimal(10, 2) @map("bonus_amount")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  campaignCode ReferralCampaignCode @relation(fields: [campaignCodeId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction  Transaction?         @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([campaignCodeId])
  @@map("referral_campaign_code_usages")
}

// ─── Admin Roles & Permissions ──────────────────────────────────────────────────

model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions AdminRolePermission[]
  users       User[]

  @@map("admin_roles")
}

model AdminRolePermission {
  id          String    @id @default(uuid())
  adminRoleId String    @map("admin_role_id")
  permission  String

  adminRole AdminRole @relation(fields: [adminRoleId], references: [id], onDelete: Cascade)

  @@unique([adminRoleId, permission])
  @@map("admin_role_permissions")
}

// ─── Job Postings ─────────────────────────────────────────────────────────────

model JobPosting {
  id               String    @id @default(uuid())
  title            String
  type             JobType
  location         String
  description      String    @db.Text
  responsibilities Json                       // string[] — array of bullet points
  isActive         Boolean   @default(false) @map("is_active")
  closingDate      DateTime? @map("closing_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("job_postings")
}

model Staff {
  id                      String                @id @default(uuid())
  name                    String
  staffCode               String                @unique @map("staff_code")
  currentRole             String                @map("current_role")
  locationId              String                @map("location_id")
  email                   String?               @unique
  phone                   String?
  dateOfBirth             DateTime?             @map("date_of_birth")
  employmentStatus        StaffEmploymentStatus @default(ACTIVE) @map("employment_status")
  reasonForExit           String?               @map("reason_for_exit")
  exitDate                DateTime?             @map("exit_date")
  archivedAt              DateTime?             @map("archived_at")
  birthdayLastEmailedYear Int?                 @map("birthday_last_emailed_year")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")

  location  StaffLocation            @relation(fields: [locationId], references: [id])
  histories StaffEmploymentHistory[]

  @@index([employmentStatus])
  @@index([locationId])
  @@map("staff")
}

model StaffEmploymentHistory {
  id               String              @id @default(uuid())
  staffId          String              @map("staff_id")
  roleTitle        String              @map("role_title")
  locationId       String              @map("location_id")
  employmentType   StaffEmploymentType @default(FULL_TIME) @map("employment_type")
  startDate        DateTime            @map("start_date")
  endDate          DateTime?           @map("end_date")
  reasonForChange  String?             @map("reason_for_change")
  notes            String?
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  staff    Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  location StaffLocation @relation(fields: [locationId], references: [id])

  @@index([staffId, startDate])
  @@index([locationId])
  @@map("staff_employment_history")
}

model StaffLocation {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  staff     Staff[]
  histories StaffEmploymentHistory[]

  @@map("staff_locations")
}
